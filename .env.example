# Bug Shoot environment example
# Copy to .env for local deployment:
#   cp .env.example .env
#
# SECURITY: all values below are local-demo defaults. Change secrets before
# exposing Bug Shoot to teammates or the internet.

# Django
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=*
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# PostgreSQL
DB_NAME=bugshoot
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Published ports
FRONTEND_PORT=80
BACKEND_PORT=8000

# Initial admin account
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Seed demo project, environment, interfaces, and chains.
LOAD_SAMPLE_DATA=True

# Gunicorn
GUNICORN_WORKERS=3

# Agent LLM
# OpenAI-compatible provider takes priority when all three values are set:
# AGENT_OPENAI_BASE_URL, AGENT_OPENAI_API_KEY, AGENT_OPENAI_MODEL.
# Otherwise Bug Shoot falls back to the bundled Ollama service.
AGENT_LLM_TIMEOUT=60
AGENT_OPENAI_BASE_URL=
AGENT_OPENAI_API_KEY=
AGENT_OPENAI_MODEL=

# Ollama fallback
OLLAMA_PORT=11434
OLLAMA_IMAGE=docker.1ms.run/ollama/ollama:latest
AGENT_OLLAMA_BASE_URL=http://ollama:11434
AGENT_OLLAMA_MODEL=qwen2.5:7b

# Production reminders:
# - Set DEBUG=False.
# - Replace SECRET_KEY, DB_PASSWORD, and DJANGO_SUPERUSER_PASSWORD.
# - Set ALLOWED_HOSTS to your domain/IP.
# - Set CORS_ALLOW_ALL_ORIGINS=False and configure CORS_ALLOWED_ORIGINS.
# - Do not expose DB_PORT or OLLAMA_PORT publicly.
